PORT=3000

HEDERA_NETWORK=hedera:testnet
FACILITATOR_URL=https://api.testnet.blocky402.com

# Global live Hedera switch. Required (with asset-specific flags) for signing/submission.
ENABLE_LIVE_HEDERA=false

# HBAR smoke path
ENABLE_HBAR_SMOKE_CHALLENGE=false
ENABLE_LIVE_HBAR_PAYMENTS=false

# USDC (HTS) smoke path
# Challenge publication only — no private key, no settlement.
ENABLE_USDC_SMOKE_CHALLENGE=false
# Live USDC settlement requires BOTH ENABLE_LIVE_HEDERA=true and this flag.
ENABLE_LIVE_USDC_PAYMENTS=false

# Verified Hedera Testnet USDC (Circle-issued HTS fungible token).
# Confirmed via Circle docs + Mirror Node (symbol=USDC, name=USD Coin, decimals=6,
# type=FUNGIBLE_COMMON, deleted=false, pause_status=NOT_APPLICABLE, treasury=0.0.5176).
# Official: https://developers.circle.com/stablecoins/usdc-contract-addresses
# Mirror:   https://testnet.mirrornode.hedera.com/api/v1/tokens/0.0.429274
USDC_TOKEN_ID=0.0.429274

# Smoke payment display amount. Smallest units = display × 10^token_decimals (validated 6).
USDC_SMOKE_AMOUNT_DISPLAY=0.01

# Optional account IDs for local development (never commit real keys).
# SHIPPER_ACCOUNT_ID=0.0.9197513
# CARRIER_ACCOUNT_ID=0.0.9215954

# Live final-demo direct HCS submitters (placeholders only).
# Each private key must control the matching Hedera Testnet account. The live
# preflight verifies all three account/public-key bindings and HBAR balances
# before topic creation. Never commit populated values.
# FINAL_DEMO_CARRIER_ALPHA_ACCOUNT_ID=<HEDERA_TESTNET_ACCOUNT_ID>
# FINAL_DEMO_CARRIER_ALPHA_PRIVATE_KEY=<ECDSA_PRIVATE_KEY>
# FINAL_DEMO_CARRIER_BETA_ACCOUNT_ID=<HEDERA_TESTNET_ACCOUNT_ID>
# FINAL_DEMO_CARRIER_BETA_PRIVATE_KEY=<ECDSA_PRIVATE_KEY>
# WEBHOOK_SIGNING_KEY=<64_HEX_CHAR_APPLICATION_SIGNING_KEY>
